<Window x:Class="CatchCatch.Views.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Input"
        Width="320" Height="150"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="True">
    <StackPanel Margin="16">
        <TextBlock x:Name="PromptText" Text="Enter value:" Margin="0,0,0,8" />
        <TextBox x:Name="InputBox" Margin="0,0,0,12" KeyDown="InputBox_KeyDown" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="75" Margin="0,0,8,0" Click="OK_Click" IsDefault="True" />
            <Button Content="Cancel" Width="75" Click="Cancel_Click" IsCancel="True" />
        </StackPanel>
    </StackPanel>
</Window>
