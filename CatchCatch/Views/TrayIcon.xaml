<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:tb="http://www.hardcodet.net/taskbar">

    <ContextMenu x:Key="TrayMenu">
        <MenuItem x:Name="MenuName" Header="Name: Anonymous" IsEnabled="False" />
        <Separator />
        <MenuItem Header="Theme">
            <MenuItem x:Name="ThemeCat" Header="Gray Cat" IsCheckable="True" IsChecked="True" />
            <MenuItem x:Name="ThemeCat2" Header="White Cat" IsCheckable="True" />
            <MenuItem x:Name="ThemeCat3" Header="Calico Cat" IsCheckable="True" />
        </MenuItem>
        <Separator />
        <MenuItem x:Name="MenuMove" Header="Move Cat" IsCheckable="True" />
        <Separator />
        <MenuItem x:Name="MenuRoom" Header="Room" IsEnabled="False" />
        <MenuItem x:Name="MenuJoin" Header="Join Room..." />
        <MenuItem x:Name="MenuLeave" Header="Leave Room" IsEnabled="False" />
        <Separator />
        <MenuItem x:Name="MenuUpdate" Header="Check for Update" />
        <Separator />
        <MenuItem x:Name="MenuQuit" Header="Quit" />
    </ContextMenu>

</ResourceDictionary>
